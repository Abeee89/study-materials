# ─── Prisma / Neon PostgreSQL ───
# Pooled connection (for application queries, use the -pooler endpoint)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB_NAME?sslmode=require"
# Direct connection (for Prisma migrations only)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB_NAME?sslmode=require"

# ─── NextAuth ───
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── OpenRouter AI ───
OPENROUTER_API_KEY="replace-with-your-api-key"
